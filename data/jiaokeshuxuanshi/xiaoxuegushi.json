[
    {
        "title":  "画",
        "notes":  [

                  ],
        "author":  "王维",
        "paragraphs":  [
                           "远看山有色，近听水无声。",
                           "春去花还在，人来鸟不惊。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·一年级上册"
                 ],
        "textbook":  "小学古诗·一年级上册"
    },
    {
        "title":  "静夜思",
        "notes":  [

                  ],
        "author":  "李白",
        "paragraphs":  [
                           "床前明月光，疑是地上霜。",
                           "举头望明月，低头思故乡。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·一年级上册"
                 ],
        "textbook":  "小学古诗·一年级上册"
    },
    {
        "title":  "咏鹅",
        "notes":  [

                  ],
        "author":  "骆宾王",
        "paragraphs":  [
                           "鹅，鹅，鹅，曲项向天歌。",
                           "白毛浮绿水，红掌拨清波。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·一年级上册"
                 ],
        "textbook":  "小学古诗·一年级上册"
    },
    {
        "title":  "小池",
        "notes":  [

                  ],
        "author":  "杨万里",
        "paragraphs":  [
                           "泉眼无声惜细流，树阴照水爱晴柔。",
                           "小荷才露尖尖角，早有蜻蜓立上头。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·一年级下册"
                 ],
        "textbook":  "小学古诗·一年级下册"
    },
    {
        "title":  "村居",
        "notes":  [

                  ],
        "author":  "高鼎",
        "paragraphs":  [
                           "草长莺飞二月天，拂堤杨柳醉春烟。",
                           "儿童散学归来早，忙趁东风放纸鸢。"
                       ],
        "dynasty":  "清代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·一年级下册"
                 ],
        "textbook":  "小学古诗·一年级下册"
    },
    {
        "title":  "所见",
        "notes":  [

                  ],
        "author":  "袁枚",
        "paragraphs":  [
                           "牧童骑黄牛，歌声振林樾。",
                           "意欲捕鸣蝉，忽然闭口立。"
                       ],
        "dynasty":  "清代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·一年级下册"
                 ],
        "textbook":  "小学古诗·一年级下册"
    },
    {
        "title":  "春晓",
        "notes":  [

                  ],
        "author":  "孟浩然",
        "paragraphs":  [
                           "春眠不觉晓，处处闻啼鸟。",
                           "夜来风雨声，花落知多少。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·一年级下册"
                 ],
        "textbook":  "小学古诗·一年级下册"
    },
    {
        "title":  "山行",
        "notes":  [
                      "深处--一作 ：生处"
                  ],
        "author":  "杜牧",
        "paragraphs":  [
                           "远上寒山石径斜，白云深处有人家。",
                           "停车坐爱枫林晚，霜叶红于二月花。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级上册"
                 ],
        "textbook":  "小学古诗·二年级上册"
    },
    {
        "title":  "赠刘景文",
        "notes":  [
                      "最是--一作 ：正是"
                  ],
        "author":  "苏轼",
        "paragraphs":  [
                           "荷尽已无擎雨盖，菊残犹有傲霜枝。",
                           "一年好景君须记，最是橙黄橘绿时。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级上册"
                 ],
        "textbook":  "小学古诗·二年级上册"
    },
    {
        "title":  "赠汪伦",
        "notes":  [

                  ],
        "author":  "李白",
        "paragraphs":  [
                           "李白乘舟将欲行，忽闻岸上踏歌声。",
                           "桃花潭水深千尺，不及汪伦送我情。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级上册"
                 ],
        "textbook":  "小学古诗·二年级上册"
    },
    {
        "title":  "回乡偶书二首·其一",
        "notes":  [
                      "鬓毛衰--一作 ：鬓毛催"
                  ],
        "author":  "贺知章",
        "paragraphs":  [
                           "少小离家老大回，乡音无改鬓毛衰。",
                           "儿童相见不相识，笑问客从何处来。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级上册"
                 ],
        "textbook":  "小学古诗·二年级上册"
    },
    {
        "title":  "绝句",
        "notes":  [

                  ],
        "author":  "杜甫",
        "paragraphs":  [
                           "两个黄鹂鸣翠柳，一行白鹭上青天。",
                           "窗含西岭千秋雪，门泊东吴万里船。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级下册"
                 ],
        "textbook":  "小学古诗·二年级下册"
    },
    {
        "title":  "望庐山瀑布",
        "notes":  [

                  ],
        "author":  "李白",
        "paragraphs":  [
                           "日照香炉生紫烟，遥看瀑布挂前川。",
                           "飞流直下三千尺，疑是银河落九天。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级下册"
                 ],
        "textbook":  "小学古诗·二年级下册"
    },
    {
        "title":  "草 / 赋得古原草送别",
        "notes":  [

                  ],
        "author":  "白居易",
        "paragraphs":  [
                           "离离原上草，一岁一枯荣。",
                           "野火烧不尽，春风吹又生。",
                           "远芳侵古道，晴翠接荒城。",
                           "又送王孙去，萋萋满别情。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级下册"
                 ],
        "textbook":  "小学古诗·二年级下册"
    },
    {
        "title":  "宿新市徐公店",
        "notes":  [

                  ],
        "author":  "杨万里",
        "paragraphs":  [
                           "篱落疏疏一径深，树头花落未成阴。",
                           "儿童急走追黄蝶，飞入菜花无处寻。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级下册"
                 ],
        "textbook":  "小学古诗·二年级下册"
    },
    {
        "title":  "敕勒歌",
        "notes":  [

                  ],
        "author":  "乐府诗集",
        "paragraphs":  [
                           "敕勒川，阴山下。天似穹庐，笼盖四野。",
                           "天苍苍，野茫茫。风吹草低见牛羊。"
                       ],
        "dynasty":  "南北朝",
        "tags":  [
                     "小学古诗",
                     "小学古诗·二年级下册"
                 ],
        "textbook":  "小学古诗·二年级下册"
    },
    {
        "title":  "夜书所见",
        "notes":  [

                  ],
        "author":  "叶绍翁",
        "paragraphs":  [
                           "萧萧梧叶送寒声，江上秋风动客情。",
                           "知有儿童挑促织，夜深篱落一灯明。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级上册"
                 ],
        "textbook":  "小学古诗·三年级上册"
    },
    {
        "title":  "饮湖上初晴后雨二首·其二",
        "notes":  [
                      "蒙--通 ：濛",
                      "淡妆浓抹--一作 ：浓妆淡抹"
                  ],
        "author":  "苏轼",
        "paragraphs":  [
                           "水光潋滟晴方好，山色空蒙雨亦奇。",
                           "欲把西湖比西子，淡妆浓抹总相宜。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级上册"
                 ],
        "textbook":  "小学古诗·三年级上册"
    },
    {
        "title":  "望天门山",
        "notes":  [

                  ],
        "author":  "李白",
        "paragraphs":  [
                           "天门中断楚江开，碧水东流至此回。",
                           "两岸青山相对出，孤帆一片日边来。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级上册"
                 ],
        "textbook":  "小学古诗·三年级上册"
    },
    {
        "title":  "九月九日忆山东兄弟",
        "notes":  [

                  ],
        "author":  "王维",
        "paragraphs":  [
                           "独在异乡为异客，每逢佳节倍思亲。",
                           "遥知兄弟登高处，遍插茱萸少一人。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级上册"
                 ],
        "textbook":  "小学古诗·三年级上册"
    },
    {
        "title":  "小儿垂钓",
        "notes":  [

                  ],
        "author":  "胡令能",
        "paragraphs":  [
                           "蓬头稚子学垂纶，侧坐莓苔草映身。",
                           "路人借问遥招手，怕得鱼惊不应人。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级上册"
                 ],
        "textbook":  "小学古诗·三年级上册"
    },
    {
        "title":  "咏柳 / 柳枝词",
        "notes":  [

                  ],
        "author":  "贺知章",
        "paragraphs":  [
                           "碧玉妆成一树高，万条垂下绿丝绦。",
                           "不知细叶谁裁出，二月春风似剪刀。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级下册"
                 ],
        "textbook":  "小学古诗·三年级下册"
    },
    {
        "title":  "春日",
        "notes":  [

                  ],
        "author":  "朱熹",
        "paragraphs":  [
                           "胜日寻芳泗水滨，无边光景一时新。",
                           "等闲识得东风面，万紫千红总是春。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级下册"
                 ],
        "textbook":  "小学古诗·三年级下册"
    },
    {
        "title":  "嫦娥",
        "notes":  [

                  ],
        "author":  "李商隐",
        "paragraphs":  [
                           "云母屏风烛影深，长河渐落晓星沉。",
                           "嫦娥应悔偷灵药，碧海青天夜夜心。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级下册"
                 ],
        "textbook":  "小学古诗·三年级下册"
    },
    {
        "title":  "乞巧",
        "notes":  [

                  ],
        "author":  "林杰",
        "paragraphs":  [
                           "七夕今宵看碧霄，牵牛织女渡河桥。",
                           "家家乞巧望秋月，穿尽红丝几万条。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级下册"
                 ],
        "textbook":  "小学古诗·三年级下册"
    },
    {
        "title":  "游子吟",
        "notes":  [

                  ],
        "author":  "孟郊",
        "paragraphs":  [
                           "慈母手中线，游子身上衣。",
                           "临行密密缝，意恐迟迟归。",
                           "谁言寸草心，报得三春晖。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·三年级下册"
                 ],
        "textbook":  "小学古诗·三年级下册"
    },
    {
        "title":  "游山西村",
        "notes":  [

                  ],
        "author":  "陆游",
        "paragraphs":  [
                           "莫笑农家腊酒浑，丰年留客足鸡豚。",
                           "山重水复疑无路，柳暗花明又一村。",
                           "箫鼓追随春社近，衣冠简朴古风存。",
                           "从今若许闲乘月，拄杖无时夜叩门。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级上册"
                 ],
        "textbook":  "小学古诗·四年级上册"
    },
    {
        "title":  "送元二使安西 / 渭城曲",
        "notes":  [
                      "客舍青青柳色新--一作 ：客舍依依杨柳春"
                  ],
        "author":  "王维",
        "paragraphs":  [
                           "渭城朝雨浥轻尘，客舍青青柳色新。",
                           "劝君更尽一杯酒，西出阳关无故人。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级上册"
                 ],
        "textbook":  "小学古诗·四年级上册"
    },
    {
        "title":  "黄鹤楼送孟浩然之广陵",
        "notes":  [
                      "唯--通 ：惟"
                  ],
        "author":  "李白",
        "paragraphs":  [
                           "故人西辞黄鹤楼，烟花三月下扬州。",
                           "孤帆远影碧空尽，唯见长江天际流。 "
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级上册"
                 ],
        "textbook":  "小学古诗·四年级上册"
    },
    {
        "title":  "题西林壁",
        "notes":  [

                  ],
        "author":  "苏轼",
        "paragraphs":  [
                           "横看成岭侧成峰，远近高低各不同。",
                           "不识庐山真面目，只缘身在此山中。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级上册"
                 ],
        "textbook":  "小学古诗·四年级上册"
    },
    {
        "title":  "过故人庄",
        "notes":  [

                  ],
        "author":  "孟浩然",
        "paragraphs":  [
                           "故人具鸡黍，邀我至田家。",
                           "绿树村边合，青山郭外斜。",
                           "开轩面场圃，把酒话桑麻。",
                           "待到重阳日，还来就菊花。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级上册"
                 ],
        "textbook":  "小学古诗·四年级上册"
    },
    {
        "title":  "乡村四月",
        "notes":  [

                  ],
        "author":  "翁卷",
        "paragraphs":  [
                           "绿遍山原白满川，子规声里雨如烟。",
                           "乡村四月闲人少，才了蚕桑又插田。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级下册"
                 ],
        "textbook":  "小学古诗·四年级下册"
    },
    {
        "title":  "独坐敬亭山",
        "notes":  [
                      "只有--一作 ：惟 / 唯"
                  ],
        "author":  "李白",
        "paragraphs":  [
                           "众鸟高飞尽，孤云独去闲。",
                           "相看两不厌，只有敬亭山。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级下册"
                 ],
        "textbook":  "小学古诗·四年级下册"
    },
    {
        "title":  "忆江南·江南好",
        "notes":  [

                  ],
        "author":  "白居易",
        "paragraphs":  [
                           "江南好，风景旧曾谙。日出江花红胜火，春来江水绿如蓝。能不忆江南？"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级下册"
                 ],
        "textbook":  "小学古诗·四年级下册"
    },
    {
        "title":  "望洞庭",
        "notes":  [
                      "山水色--一作 ：山水翠"
                  ],
        "author":  "刘禹锡",
        "paragraphs":  [
                           "湖光秋月两相和，潭面无风镜未磨。",
                           "遥望洞庭山水色，白银盘里一青螺。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级下册"
                 ],
        "textbook":  "小学古诗·四年级下册"
    },
    {
        "title":  "渔歌子·西塞山前白鹭飞",
        "notes":  [

                  ],
        "author":  "张志和",
        "paragraphs":  [
                           "西塞山前白鹭飞，桃花流水鳜鱼肥。",
                           "青箬笠，绿蓑衣，斜风细雨不须归。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级下册"
                 ],
        "textbook":  "小学古诗·四年级下册"
    },
    {
        "title":  "四时田园杂兴·其二",
        "notes":  [
                      "惟--通 唯"
                  ],
        "author":  "范成大",
        "paragraphs":  [
                           "梅子金黄杏子肥，麦花雪白菜花稀。",
                           "日长篱落无人过，惟有蜻蜓蛱蝶飞。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·四年级下册"
                 ],
        "textbook":  "小学古诗·四年级下册"
    },
    {
        "title":  "长相思·山一程",
        "notes":  [

                  ],
        "author":  "纳兰性德",
        "paragraphs":  [
                           "山一程，水一程，身向榆关那畔行，夜深千帐灯。",
                           "风一更，雪一更，聒碎乡心梦不成，故园无此声。"
                       ],
        "dynasty":  "清代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级上册"
                 ],
        "textbook":  "小学古诗·五年级上册"
    },
    {
        "title":  "秋思",
        "notes":  [

                  ],
        "author":  "张籍",
        "paragraphs":  [
                           "洛阳城里见秋风，欲作家书意万重。",
                           "复恐匆匆说不尽，行人临发又开封。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级上册"
                 ],
        "textbook":  "小学古诗·五年级上册"
    },
    {
        "title":  "泊船瓜洲",
        "notes":  [

                  ],
        "author":  "王安石",
        "paragraphs":  [
                           "京口瓜洲一水间，钟山只隔数重山。",
                           "春风又绿江南岸，明月何时照我还？"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级上册"
                 ],
        "textbook":  "小学古诗·五年级上册"
    },
    {
        "title":  "卜算子·咏梅",
        "notes":  [

                  ],
        "author":  "陆游",
        "paragraphs":  [
                           "驿外断桥边，寂寞开无主。已是黄昏独自愁，更著风和雨。",
                           "无意苦争春，一任群芳妒。零落成泥碾作尘，只有香如故。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级上册"
                 ],
        "textbook":  "小学古诗·五年级上册"
    },
    {
        "title":  "清平乐·村居",
        "notes":  [
                      "亡--通 ：无"
                  ],
        "author":  "辛弃疾",
        "paragraphs":  [
                           "茅檐低小，溪上青青草。",
                           "醉里吴音相媚好，白发谁家翁媪？",
                           "大儿锄豆溪东，中儿正织鸡笼。",
                           "最喜小儿亡赖，溪头卧剥莲蓬。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级下册"
                 ],
        "textbook":  "小学古诗·五年级下册"
    },
    {
        "title":  "牧童",
        "notes":  [

                  ],
        "author":  "吕岩",
        "paragraphs":  [
                           "草铺横野六七里，笛弄晚风三四声。",
                           "归来饱饭黄昏后，不脱蓑衣卧月明。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级下册"
                 ],
        "textbook":  "小学古诗·五年级下册"
    },
    {
        "title":  "舟过安仁",
        "notes":  [

                  ],
        "author":  "杨万里",
        "paragraphs":  [
                           "一叶渔船两小童，收篙停棹坐船中。",
                           "怪生无雨都张伞，不是遮头是使风。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级下册"
                 ],
        "textbook":  "小学古诗·五年级下册"
    },
    {
        "title":  "浪淘沙·九曲黄河万里沙",
        "notes":  [

                  ],
        "author":  "刘禹锡",
        "paragraphs":  [
                           "九曲黄河万里沙，浪淘风簸自天涯。",
                           "如今直上银河去，同到牵牛织女家。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·五年级下册"
                 ],
        "textbook":  "小学古诗·五年级下册"
    },
    {
        "title":  "春夜喜雨",
        "notes":  [

                  ],
        "author":  "杜甫",
        "paragraphs":  [
                           "好雨知时节，当春乃发生。",
                           "随风潜入夜，润物细无声。",
                           "野径云俱黑，江船火独明。",
                           "晓看红湿处，花重锦官城。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级上册"
                 ],
        "textbook":  "小学古诗·六年级上册"
    },
    {
        "title":  "天净沙·秋",
        "notes":  [

                  ],
        "author":  "白朴",
        "paragraphs":  [
                           "孤村落日残霞，轻烟老树寒鸦，一点飞鸿影下。青山绿水，白草红叶黄花。"
                       ],
        "dynasty":  "元代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级上册"
                 ],
        "textbook":  "小学古诗·六年级上册"
    },
    {
        "title":  "西江月·夜行黄沙道中",
        "notes":  [
                      "溪桥--一作 ：溪头"
                  ],
        "author":  "辛弃疾",
        "paragraphs":  [
                           "明月别枝惊鹊，清风半夜鸣蝉。稻花香里说丰年，听取蛙声一片。",
                           "七八个星天外，两三点雨山前。旧时茅店社林边，路转溪桥忽见。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级上册"
                 ],
        "textbook":  "小学古诗·六年级上册"
    },
    {
        "title":  "采薇(节选)",
        "notes":  [

                  ],
        "author":  "佚名",
        "paragraphs":  [
                           "昔我往矣，杨柳依依。",
                           "今我来思，雨雪霏霏。",
                           "行道迟迟，载渴载饥。",
                           "我心悲伤，莫知我哀！"
                       ],
        "dynasty":  "先秦",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级上册"
                 ],
        "textbook":  "小学古诗·六年级上册"
    },
    {
        "title":  "采薇",
        "notes":  [

                  ],
        "author":  "佚名",
        "paragraphs":  [
                           "采薇采薇，薇亦作止。曰归曰归，岁亦莫止。 靡室靡家，猃狁之故。不遑启居，猃狁之故。",
                           "采薇采薇，薇亦柔止。曰归曰归，心亦忧止。 忧心烈烈，载饥载渴。我戍未定，靡使归聘。",
                           "采薇采薇，薇亦刚止。曰归曰归，岁亦阳止。 王事靡盬，不遑启处。忧心孔疚，我行不来！",
                           "彼尔维何？维常之华。彼路斯何？君子之车。 戎车既驾，四牡业业。岂敢定居？一月三捷。",
                           "驾彼四牡，四牡骙骙。君子所依，小人所腓。 四牡翼翼，象弭鱼服。岂不日戒？猃狁孔棘！",
                           "昔我往矣，杨柳依依。今我来思，雨雪霏霏。 行道迟迟，载渴载饥。我心伤悲，莫知我哀！"
                       ],
        "dynasty":  "先秦",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级上册"
                 ],
        "textbook":  "小学古诗·六年级上册"
    },
    {
        "title":  "天竺寺八月十五日夜桂子",
        "notes":  [

                  ],
        "author":  "皮日休",
        "paragraphs":  [
                           "玉颗珊珊下月轮，殿前拾得露华新。",
                           "至今不会天中事，应是嫦娥掷与人。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "七步诗",
        "notes":  [
                      "菽--一作 ：豉"
                  ],
        "author":  "曹植",
        "paragraphs":  [
                           "煮豆燃豆萁，豆在釜中泣。",
                           "本是同根生，相煎何太急？",
                           "版本二",
                           "煮豆持作羹，漉菽以为汁。",
                           "萁在釜下燃，豆在釜中泣。",
                           "本自同根生，相煎何太急？"
                       ],
        "dynasty":  "两汉",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "闻官军收河南河北",
        "notes":  [

                  ],
        "author":  "杜甫",
        "paragraphs":  [
                           "剑外忽传收蓟北，初闻涕泪满衣裳。",
                           "却看妻子愁何在，漫卷诗书喜欲狂。",
                           "白日放歌须纵酒，青春作伴好还乡。",
                           "即从巴峡穿巫峡，便下襄阳向洛阳。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "江畔独步寻花·其六",
        "notes":  [

                  ],
        "author":  "杜甫",
        "paragraphs":  [
                           "黄四娘家花满蹊，千朵万朵压枝低。",
                           "留连戏蝶时时舞，自在娇莺恰恰啼。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "鸟鸣涧",
        "notes":  [

                  ],
        "author":  "王维",
        "paragraphs":  [
                           "人闲桂花落，夜静春山空。",
                           "月出惊山鸟，时鸣春涧中。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "元日",
        "notes":  [

                  ],
        "author":  "王安石",
        "paragraphs":  [
                           "爆竹声中一岁除，春风送暖入屠苏。",
                           "千门万户曈曈日，总把新桃换旧符。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "浣溪沙·游蕲水清泉寺",
        "notes":  [
                      "潇潇--一作 ：萧萧"
                  ],
        "author":  "苏轼",
        "paragraphs":  [
                           "游蕲水清泉寺，寺临兰溪，溪水西流。",
                           "",
                           "山下兰芽短浸溪，松间沙路净无泥，潇潇暮雨子规啼。",
                           "谁道人生无再少？门前流水尚能西！休将白发唱黄鸡。"
                       ],
        "dynasty":  "宋代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "石灰吟",
        "notes":  [
                      "千锤万凿出深山--一作 ：千锤万击出深山 / 千鎚万击出深山",
                      "粉骨碎身全不怕--一作 ：粉骨碎身全不惜 / 粉身碎骨浑不怕 / 粉身碎骨全不怕"
                  ],
        "author":  "于谦",
        "paragraphs":  [
                           "千锤万凿出深山，烈火焚烧若等闲。",
                           "粉骨碎身全不怕，要留清白在人间。",
                           "",
                           "",
                           ""
                       ],
        "dynasty":  "明代",
        "tags":  [
