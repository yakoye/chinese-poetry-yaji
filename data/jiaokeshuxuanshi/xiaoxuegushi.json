                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "竹石",
        "notes":  [

                  ],
        "author":  "郑燮",
        "paragraphs":  [
                           "咬定青山不放松，立根原在破岩中。",
                           "千磨万击还坚劲，任尔东西南北风。(坚",
                           "劲",
                           "一作：韧)"
                       ],
        "dynasty":  "清代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    },
    {
        "title":  "芙蓉楼送辛渐",
        "notes":  [

                  ],
        "author":  "王昌龄",
        "paragraphs":  [
                           "寒雨连江夜入吴，平明送客楚山孤。",
                           "洛阳亲友如相问，一片冰心在玉壶。"
                       ],
        "dynasty":  "唐代",
        "tags":  [
                     "小学古诗",
                     "小学古诗·六年级下册"
                 ],
        "textbook":  "小学古诗·六年级下册"
    }
]
